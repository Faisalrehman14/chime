# --- Local ---
GMAIL_CREDENTIALS_FILE=credentials/credentials.json
GMAIL_TOKEN_FILE=credentials/token.json
WEB_HOST=127.0.0.1
WEB_PORT=8787
BROWSER_MODE=existing
HEADLESS=false

# --- Session (multi-user login cookies) ---
# SESSION_SECRET=random-64-char-hex

# --- Google OAuth (server-side — user ko paste nahi karna) ---
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...

# --- Railway / Cloud (set in Railway Variables) ---
# PORT=                    (Railway auto)
# RAILWAY_PUBLIC_DOMAIN=   (Railway auto)
# PUBLIC_BASE_URL=https://your-app.up.railway.app
# GOOGLE_CLIENT_ID=        (same as above — 1 dafa Railway mein set karo)
# GOOGLE_CLIENT_SECRET=
# BROWSER_MODE=launch
# HEADLESS=true

CHIME_SENDER=alerts@account.chime.com
CHECK_INTERVAL_SECONDS=10

CARD_NUMBER=
CARD_EXPIRY=12/28
CARD_CVV=
CARD_ZIP=
CARDHOLDER_NAME=

BROWSER_TIMEOUT_MS=90000
AUTO_START_WATCHER=true

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
